<% layout('layouts/boilerplate') -%>
  <div class="row">
    <!-- Page Title -->
    <div class="col-8 offset-2 mt-3 mb-3">
      <h3>
        <%= listing.title %>
      </h3>
    </div>
    <!-- Listing Card -->
    <div class="card col-6 offset-3 show-card listing-card">
      <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing image">
      <div class="card-body">
        <p class="card-text">
          <b>Owned by</b>
          <i>
            <%= listing.owner ? listing.owner.username : "Unknown Owner" %>
          </i>
        </p>
        <p class="card-text">
          <%= listing.description %>
        </p>
        <p class="card-text">₹ <%= listing.price.toLocaleString("en-IN") %>
        </p>
        <p class="card-text">
          <%= listing.location %>
        </p>
        <p class="card-text">
          <%= listing.country %>
        </p>
      </div>
    </div>
    <!-- Owner Buttons -->
    <% if (currentUser && listing.owner._id.equals(currentUser._id)) { %>
      <div class="d-flex justify-content-center align-items-center gap-3 mt-4 mb-5">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark add-btn px-4">Edit</a>
        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
          <button class="btn btn-dark px-4" type="submit">Delete</button>
        </form>
      </div>
    <% } %>
    <!-- Review Section -->
    <div class="col-8 offset-3 mb-3">
      <hr>
      <!-- Review Form (only if user is logged in AND not the owner) -->
      <% if (currentUser ) { %>
      <h4>Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
          <!-- Rating -->
          <div class="mb-3 mt-3">
            <label for="rating" class="form-label">Rating</label>
            <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
          </div>
          <!-- Comment -->
          <div class="mb-3 mt-3">
            <label for="comment" class="form-label">Comment</label>
            <textarea id="comment" name="review[comment]" rows="4" class="form-control" required></textarea>
            <div class="invalid-feedback">Please provide a comment.</div>
            <div class="valid-feedback">Looks good!</div>
          </div>
          <button class="btn btn-outline-dark" type="submit">Submit Review</button>
        </form>
        <hr>
      <% } %>
      <!-- All Reviews -->
      <p>
        <b>All Reviews</b>
      </p>
      <div class="row">
        <% for (let review of listing.reviews) { %>
          <div class="card col-5 ms-3 mb-3">
            <div class="card-body">
              <h5 class="card-title">@
                <%= review.author.username %>
              </h5>
              <p class="card-text">
                <%= review.comment %>
              </p>
              <p class="card-text">
                Rating: <%= review.rating %> / 5
              </p>
            </div>
            <!-- Delete button only for the author of the review -->
            <% if (currentUser && review.author && review.author._id.equals(currentUser._id)) { %>
              <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="mb-3">
                 <button class="btn btn-outline-secondary btn-sm">Delete</button>
              </form>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>